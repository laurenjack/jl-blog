---
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const latest = (cat: string) => posts.find((p) => p.data.category === cat);
const essay = latest('essay');
const research = latest('research');
const explainer = latest('explainer');
---

<header class="site-header">
	<nav>
		<a class="site-title" href="/">{SITE_TITLE}</a>
		<span class="nav-links">
			{essay && <a class="essay" href={`/blog/${essay.id}/`}>Essays</a>}
			{research && <a class="research" href={`/blog/${research.id}/`}>Research</a>}
			{explainer && <a class="explainer" href={`/blog/${explainer.id}/`}>Explainers</a>}
		</span>
	</nav>
</header>
